<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="ReviFlash.App"
             xmlns:local="using:ReviFlash"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="AppBackground" Color="#0f0f13" />
                    
                    <SolidColorBrush x:Key="CardBackground" Color="#801E1E24" /> 
                    <SolidColorBrush x:Key="CardBorder" Color="#30FFFFFF" />
                    <SolidColorBrush x:Key="BadgeBackground" Color="#40000000" />
                    <SolidColorBrush x:Key="StatTileBackground" Color="#20FFFFFF" />
                    
                    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#A0A0A5" />
                    <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#FFFFFF" />
                    <SolidColorBrush x:Key="IconForeground" Color="#FFFFFF" />
                    
                    <Color x:Key="GradientStart">#4158D0</Color>
                    <Color x:Key="GradientMiddle">#C850C0</Color>
                    <Color x:Key="GradientEnd">#FFCC70</Color>
                </ResourceDictionary>

                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="AppBackground" Color="#FAFAFA" />
                    
                    <SolidColorBrush x:Key="CardBackground" Color="#FFFFFF" /> 
                    <SolidColorBrush x:Key="CardBorder" Color="#D0D0D0" />
                    <SolidColorBrush x:Key="BadgeBackground" Color="#35E8E8E8" />
                    <SolidColorBrush x:Key="StatTileBackground" Color="#60B0B0B0" />
                    
                    <SolidColorBrush x:Key="TextPrimary" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#3A4A5A" />
                    <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#0A0A0A" />
                    <SolidColorBrush x:Key="IconForeground" Color="#0A0A0A" />
                    
                    <Color x:Key="GradientStart">#F5F5F5</Color>
                    <Color x:Key="GradientMiddle">#EBEBEB</Color>
                    <Color x:Key="GradientEnd">#E0E0E0</Color>
                </ResourceDictionary>

                <ResourceDictionary x:Key="{x:Static local:AppThemes.Pride}">
                    <SolidColorBrush x:Key="AppBackground" Color="#E7F7FF" />

                    <SolidColorBrush x:Key="CardBackground" Color="#D9ECFF" />
                    <SolidColorBrush x:Key="CardBorder" Color="#E240AC" />
                    <SolidColorBrush x:Key="BadgeBackground" Color="#B8FF4DB8" />
                    <SolidColorBrush x:Key="StatTileBackground" Color="#8A5CCEFF" />

                    <SolidColorBrush x:Key="TextPrimary" Color="#0A1E4A" />
                    <SolidColorBrush x:Key="TextSecondary" Color="#194A9C" />
                    <SolidColorBrush x:Key="PrimaryButtonForeground" Color="#0A1E4A" />
                    <SolidColorBrush x:Key="IconForeground" Color="#0A1E4A" />

                    <Color x:Key="GradientStart">#7DDBFF</Color>
                    <Color x:Key="GradientMiddle">#FF3EAF</Color>
                    <Color x:Key="GradientEnd">#4FB9FF</Color>
                </ResourceDictionary>

                </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
</Application>