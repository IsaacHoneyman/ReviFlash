<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    xmlns:vm="using:ReviFlash.ViewModels"
    xmlns:models="using:ReviFlash.Models"
    xmlns:math="clr-namespace:AvaloniaMath.Controls;assembly=AvaloniaMath"
    xmlns:converters="using:ReviFlash.Converters"
    x:Class="ReviFlash.Views.MainWindow"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/avalonia-logo.ico"
    Title="ReviFlash"
    Width="1000" Height="600"
    WindowStartupLocation="CenterScreen"
    WindowState="FullScreen"
    SystemDecorations="None"
    KeyDown="Window_KeyDown"
    Background="{DynamicResource AppBackground}">

    <Window.Styles>
        <Style Selector="Rectangle.animatedGradient">
            <Style.Animations>
                <Animation Duration="0:0:14" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                    <KeyFrame Cue="25%">
                        <Setter Property="RotateTransform.Angle" Value="105" />
                    </KeyFrame>
                    <KeyFrame Cue="50%">
                        <Setter Property="RotateTransform.Angle" Value="190" />
                    </KeyFrame>
                    <KeyFrame Cue="75%">
                        <Setter Property="RotateTransform.Angle" Value="282" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>

        <Style Selector="Rectangle.animatedGradientReverse">
            <Style.Animations>
                <Animation Duration="0:0:11" IterationCount="Infinite">
                    <KeyFrame Cue="0%">
                        <Setter Property="RotateTransform.Angle" Value="360" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="RotateTransform.Angle" Value="0" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
    </Window.Styles>

    <Window.Resources>
        <converters:MixedMathSegmentsConverter x:Key="MixedMathSegmentsConverter" />
        <converters:IsMathDelimitedConverter x:Key="IsMathDelimitedConverter" />
        <converters:IsNotMathDelimitedConverter x:Key="IsNotMathDelimitedConverter" />
        <converters:StripMathDelimitersConverter x:Key="StripMathDelimitersConverter" />
    </Window.Resources>

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:MainWindowViewModel}">

            <Grid RowDefinitions="86, *">

                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="24, 16, 24, 0">
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12"
                        VerticalAlignment="Center">
                        <TextBlock Text="Revi Flash" FontSize="30" FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimary}" />
                        <Border Background="{DynamicResource BadgeBackground}" CornerRadius="13"
                            Padding="12,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="{Binding StreakText}" FontSize="13"
                                    FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"
                                    VerticalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <TextBlock Text="{Binding VersionText}" FontSize="12" Foreground="{DynamicResource TextSecondary}"
                        VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0" />

                    <Button Grid.Column="1" Click="SettingsButton_Click" Background="Transparent"
                        CornerRadius="18" Width="56" Height="56" Cursor="Hand"
                        VerticalAlignment="Center">
                        <TextBlock Text="⚙️" FontSize="28" HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1" ColumnDefinitions="*, 290" Margin="24, 12, 24, 24">

                    <Grid Grid.Column="0" RowDefinitions="Auto, *" Margin="0, 0, 24, 0">

                        <Grid Grid.Row="0" ColumnDefinitions="*, Auto, Auto" Margin="0, 0, 0, 18">
                            <TextBox Grid.Column="0"
                                Text="{Binding SearchText, Mode=TwoWay}"
                                Watermark="Search flashcard sets..."
                                CornerRadius="8" Padding="10, 7" FontSize="14" Margin="0, 0, 12, 0"
                                Background="{DynamicResource CardBackground}"
                                Foreground="{DynamicResource TextPrimary}" />

                            <Button Grid.Column="1"
                                Click="MultiSelectDecks_Click"
                                Content="{Binding MultiSelectPrimaryButtonText}"
                                CornerRadius="8" Padding="14, 8" FontSize="14" FontWeight="SemiBold"
                                Background="{DynamicResource BadgeBackground}" Foreground="{DynamicResource TextPrimary}"
                                Cursor="Hand" Margin="0,0,12,0" />

                            <Button Grid.Column="2"
                                Click="CreateDeck_Click"
                                Content="+ Create New Set"
                                CornerRadius="8" Padding="14, 8" FontSize="14" FontWeight="Bold"
                                Background="{DynamicResource GradientStart}" Foreground="{DynamicResource PrimaryButtonForeground}"
                                Cursor="Hand" />
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding FilteredDecks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel HorizontalAlignment="Left" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>

                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="models:FlashCardDeck">
                                        <Border Width="250" Height="138"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource CardBorder}"
                                            BorderThickness="1.5" CornerRadius="20"
                                            Margin="0, 0, 16, 16" Padding="16" Cursor="Hand"
                                            Focusable="True"
                                            PointerPressed="DeckCard_Click"
                                            KeyDown="DeckCard_KeyDown">

                                            <Grid RowDefinitions="Auto, *">

                                                <Grid Grid.Row="0" ColumnDefinitions="Auto, *"
                                                    VerticalAlignment="Top">
                                                    <Border Grid.Column="0"
                                                        HorizontalAlignment="Left"
                                                        VerticalAlignment="Center"
                                                        Background="{DynamicResource BadgeBackground}"
                                                        CornerRadius="8" Padding="8,4">
                                                        <StackPanel Orientation="Horizontal"
                                                            Spacing="4">
                                                            <TextBlock Text="{Binding CardCount}"
                                                                FontSize="12" FontWeight="Bold"
                                                                Foreground="{DynamicResource TextPrimary}" />
                                                            <TextBlock Text="Cards" FontSize="10"
                                                                VerticalAlignment="Center"
                                                                Foreground="{DynamicResource TextSecondary}" />
                                                        </StackPanel>
                                                    </Border>

                                                    <StackPanel Grid.Column="1"
                                                        HorizontalAlignment="Right"
                                                        VerticalAlignment="Center"
                                                        Orientation="Horizontal"
                                                        Spacing="8">
                                                        <Button Click="EditDeck_Click"
                                                            Background="#70FFFFFF" CornerRadius="8"
                                                            Padding="12,6" Height="30"
                                                            MinHeight="30"
                                                            VerticalContentAlignment="Center"
                                                            Cursor="Hand">
                                                            <TextBlock Text="✏️" FontSize="12"
                                                                Foreground="{DynamicResource IconForeground}" />
                                                        </Button>

                                                        <Button Click="DeckStats_Click"
                                                            Background="#7044AAFF" CornerRadius="8"
                                                            Padding="12,6" Height="30"
                                                            MinHeight="30"
                                                            VerticalContentAlignment="Center"
                                                            Cursor="Hand"
                                                            ToolTip.Tip="View Deck Stats">
                                                            <TextBlock Text="📊" FontSize="12"
                                                                Foreground="{DynamicResource IconForeground}" />
                                                        </Button>

                                                        <Button Click="DeleteDeck_Click"
                                                            Background="#90FF4444" CornerRadius="8"
                                                            Padding="12,6" Height="30"
                                                            MinHeight="30"
                                                            VerticalContentAlignment="Center"
                                                            Cursor="Hand"
                                                            ToolTip.Tip="Delete Deck">
                                                            <TextBlock Text="🗑️" FontSize="12"
                                                                Foreground="{DynamicResource IconForeground}" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <StackPanel Grid.Row="1" VerticalAlignment="Bottom">
                                                    <TextBlock Text="{Binding Name}" FontSize="22"
                                                        FontWeight="SemiBold"
                                                        Foreground="{DynamicResource TextPrimary}"
                                                        TextWrapping="Wrap" />
                                                    <TextBlock Text="Click to review" FontSize="14"
                                                        Foreground="{DynamicResource TextSecondary}"
                                                        IsVisible="{Binding !IsSelectedForMultiReview}"
                                                        Margin="0, 12, 0, 0" />
                                                    <TextBlock Text="Selected for multi review" FontSize="14"
                                                        Foreground="{DynamicResource GradientStart}"
                                                        IsVisible="{Binding IsSelectedForMultiReview}"
                                                        Margin="0, 12, 0, 0" />
                                                </StackPanel>

                                            </Grid>

                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>

                    <Border Grid.Column="1"
                        Background="{DynamicResource CardBackground}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1.5"
                        CornerRadius="20"
                        Padding="20">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Grid.Column="0" Text="Overall Stats" FontSize="18" FontWeight="Bold"
                                    Foreground="{DynamicResource TextPrimary}"
                                    IsVisible="{Binding !IsViewingDeckStats}" />
                                <TextBlock Grid.Column="0" Text="{Binding SelectedDeckForStats.Name, StringFormat='{}{0} Stats'}" FontSize="18" FontWeight="Bold"
                                    Foreground="{DynamicResource TextPrimary}"
                                    IsVisible="{Binding IsViewingDeckStats}" />
                                
                                <Button Grid.Column="1" Click="CloseDecKStats_Click" 
                                    Background="#70FFFFFF" CornerRadius="4" Padding="4" Height="28" Width="28"
                                    IsVisible="{Binding IsViewingDeckStats}" VerticalAlignment="Center" HorizontalAlignment="Right"
                                    Cursor="Hand">
                                    <TextBlock Text="✕" FontSize="16" Foreground="{DynamicResource IconForeground}" 
                                        VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Button>
                            </Grid>

                            <ComboBox ItemsSource="{Binding TimePeriods}"
                                SelectedItem="{Binding SelectedTimePeriod}"
                                CornerRadius="8"
                                Padding="12, 8" FontSize="14"
                                Background="{DynamicResource StatTileBackground}"
                                Foreground="{DynamicResource TextPrimary}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="vm:MainWindowViewModel+TimePeriodOption">
                                        <TextBlock Text="{Binding Label}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>

                            <Border Background="{DynamicResource StatTileBackground}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Total Questions"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding TotalQuestions}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource StatTileBackground}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Total Correct"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding TotalCorrect}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource StatTileBackground}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Accuracy Rate"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding Percentage, StringFormat='{}{0}%'}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource StatTileBackground}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Grade"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding Grade}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource StatTileBackground}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Total Time"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding TotalTimeFormatted}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>

                            <Border Background="{DynamicResource StatTileBackground}"
                                IsVisible="{Binding !IsViewingDeckStats}"
                                CornerRadius="10"
                                Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Best Ever Streak"
                                        Foreground="{DynamicResource TextSecondary}" FontSize="12" />
                                    <TextBlock Text="{Binding BestEverStreakText}" Foreground="{DynamicResource TextPrimary}"
                                        FontSize="24" FontWeight="Bold" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:ReviewViewModel}">
            <Grid RowDefinitions="Auto, *">
                <!-- Top Bar with Timer, Progress, and Quit Button -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto, *" Margin="24, 16, 24, 16" VerticalAlignment="Center">
                    <!-- Timer -->
                    <StackPanel Grid.Column="0" IsVisible="{Binding ShouldShowTimer}">
                        <TextBlock Text="Time" FontSize="14" Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock Text="{Binding TimerText}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" />
                    </StackPanel>
                    
                    <!-- Progress (Center) -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center" IsVisible="{Binding ShouldShowProgress}">
                        <TextBlock Text="Progress" FontSize="14" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ProgressCardCount}" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Center" />
                        <TextBlock Text="{Binding ProgressPercentage, StringFormat='{}{0}%'}" FontSize="14" Foreground="{DynamicResource TextSecondary}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                        <ProgressBar Value="{Binding ProgressPercentage}" Maximum="100" Height="4" CornerRadius="2" Margin="0,4,0,0" Width="100" />
                    </StackPanel>
                    
                    <!-- Quit Button -->
                    <Button Grid.Column="2" Click="QuitSession_Click" 
                        Background="#70FFFFFF" CornerRadius="4" Padding="4" Height="28" Width="28"
                        VerticalAlignment="Top" Margin="0, 0, 0, 0" HorizontalAlignment="Right" Cursor="Hand"
                        ToolTip.Tip="Quit and save progress">
                        <TextBlock Text="✕" FontSize="16" Foreground="{DynamicResource IconForeground}" 
                            VerticalAlignment="Center" HorizontalAlignment="Center" />
                    </Button>
                </Grid>

                <!-- Review Card -->
                <Grid Grid.Row="1" Margin="0,0,0,16">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" VerticalAlignment="Center">
                    <Border Width="560" Background="{DynamicResource CardBackground}" CornerRadius="26"
                        Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <StackPanel Spacing="20">
                        <TextBlock Text="{Binding CurrentNumber, StringFormat='Card {0} of {1}'}" 
                            HorizontalAlignment="Center"
                            FontSize="16"
                            Foreground="{DynamicResource TextSecondary}" />

                        <ItemsControl ItemsSource="{Binding CurrentCard.Front, Converter={StaticResource MixedMathSegmentsConverter}}"
                            HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                    <Grid>
                                        <TextBlock Text="{Binding Content}"
                                            TextWrapping="Wrap"
                                            FontSize="18"
                                            Foreground="{DynamicResource TextPrimary}"
                                            IsVisible="{Binding IsText}" />
                                        <math:FormulaBlock Formula="{Binding Content}" IsVisible="{Binding IsMath}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="{DynamicResource CardBorder}" Opacity="0.3"
                            Margin="0,20" />

                        <ItemsControl ItemsSource="{Binding CurrentCard.Back, Converter={StaticResource MixedMathSegmentsConverter}}"
                            IsVisible="{Binding ShowBackAnswer}" HorizontalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                    <Grid>
                                        <TextBlock Text="{Binding Content}"
                                            TextWrapping="Wrap"
                                            FontSize="18"
                                            Foreground="{DynamicResource TextSecondary}"
                                            IsVisible="{Binding IsText}" />
                                        <math:FormulaBlock Formula="{Binding Content}" IsVisible="{Binding IsMath}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Spacing="15" Margin="0,20,0,0">
                            <!-- Flip Card: Show Answer Button -->
                            <Button Content="Show Answer" Click="ShowAnswer_Click"
                                IsVisible="{Binding ShowAnswerButtonVisible}"
                                FontSize="16"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                            
                            <!-- Type Card: Text Input -->
                            <StackPanel Spacing="10" IsVisible="{Binding IsTypeCard}">
                                <!-- Input Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding !IsAnswerChecked}">
                                    <TextBox Text="{Binding UserTypedAnswer, Mode=TwoWay}"
                                        Watermark="Type your answer..."
                                        CornerRadius="8" Padding="12, 10" FontSize="16"
                                        Background="{DynamicResource CardBackground}"
                                        Foreground="{DynamicResource TextPrimary}"
                                        BorderBrush="{DynamicResource CardBorder}"
                                        BorderThickness="1.5" />
                                    <Button Content="Submit Answer" Click="SubmitAnswer_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="{DynamicResource GradientStart}" Foreground="{DynamicResource PrimaryButtonForeground}" />
                                </StackPanel>

                                <!-- Result Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsAnswerChecked}">
                                    <!-- Correct/Incorrect Visual -->
                                    <TextBlock Text="✓ Correct!" FontSize="24" FontWeight="Bold"
                                        Foreground="#4444FF44" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsAnswerCorrect}" />
                                    <TextBlock Text="✕ Incorrect" FontSize="24" FontWeight="Bold"
                                        Foreground="#FF4444" HorizontalAlignment="Center"
                                        IsVisible="{Binding !IsAnswerCorrect}" />
                                    
                                    <!-- Show Correct Answer -->
                                    <StackPanel>
                                        <TextBlock Text="Correct Answer:" 
                                            Foreground="{DynamicResource TextSecondary}" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentTypeCardAnswer}"
                                            Foreground="{DynamicResource TextPrimary}" FontSize="16"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                    
                                    <!-- Next Button -->
                                    <Button Content="Next" Click="NextCard_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Multi Choice Card -->
                            <StackPanel Spacing="10" IsVisible="{Binding IsMultiChoiceCard}">
                                <!-- Input Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding !IsAnswerChecked}">
                                    <TextBlock Text="Select all options you think are correct:" FontSize="14"
                                        Foreground="{DynamicResource TextSecondary}" />

                                    <ItemsControl ItemsSource="{Binding MultiChoiceAnswerOptions}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ReviewOptionItem">
                                                <Border Background="#18000000" BorderBrush="{DynamicResource CardBorder}"
                                                    BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,2,0,2">
                                                    <Grid ColumnDefinitions="Auto, *">
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                            VerticalAlignment="Center" Margin="0,0,10,0" />
                                                        <ItemsControl Grid.Column="1" ItemsSource="{Binding OptionText, Converter={StaticResource MixedMathSegmentsConverter}}"
                                                            HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                    <StackPanel Margin="0,0,2,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Content}" FontSize="16"
                                                                            TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="{DynamicResource TextPrimary}"
                                                                            IsVisible="{Binding IsText}" />
                                                                        <math:FormulaBlock Formula="{Binding Content}" FontSize="16"
                                                                            HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                            IsVisible="{Binding IsMath}"
                                                                            Foreground="{DynamicResource TextPrimary}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="Submit Answer" Click="SubmitAnswer_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="{DynamicResource GradientStart}" Foreground="{DynamicResource PrimaryButtonForeground}" />
                                </StackPanel>

                                <!-- Result Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsAnswerChecked}">
                                    <TextBlock Text="✓ Correct!" FontSize="24" FontWeight="Bold"
                                        Foreground="#4444FF44" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsAnswerCorrect}" />
                                    <TextBlock Text="✕ Incorrect" FontSize="24" FontWeight="Bold"
                                        Foreground="#FF4444" HorizontalAlignment="Center"
                                        IsVisible="{Binding !IsAnswerCorrect}" />

                                    <StackPanel>
                                        <TextBlock Text="Correct options:" FontSize="14"
                                            Foreground="{DynamicResource TextSecondary}" />
                                        <ItemsControl ItemsSource="{Binding MultiChoiceAnswerOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ReviewOptionItem">
                                                    <StackPanel Spacing="6" Margin="0,2,0,0" IsVisible="{Binding IsCorrect}" Orientation="Horizontal">
                                                        <TextBlock Text="✓" FontSize="15" Foreground="#44CC88" VerticalAlignment="Top" />
                                                        <ItemsControl ItemsSource="{Binding OptionText, Converter={StaticResource MixedMathSegmentsConverter}}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                    <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Content}" FontSize="15" TextWrapping="Wrap"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#44CC88"
                                                                            IsVisible="{Binding IsText}" />
                                                                        <math:FormulaBlock Formula="{Binding Content}" FontSize="15"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#44CC88"
                                                                            IsVisible="{Binding IsMath}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel IsVisible="{Binding HasSelectedWrongOptions}">
                                        <TextBlock Text="You selected these incorrectly:" FontSize="14"
                                            Foreground="#FF8888" />
                                        <ItemsControl ItemsSource="{Binding SelectedWrongOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="sys:String">
                                                    <StackPanel Spacing="6" Margin="0,2,0,0" Orientation="Horizontal">
                                                        <TextBlock Text="✕" FontSize="14" Foreground="#FF8888" VerticalAlignment="Top" />
                                                        <ItemsControl ItemsSource="{Binding ., Converter={StaticResource MixedMathSegmentsConverter}}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                    <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#FF8888"
                                                                            IsVisible="{Binding IsText}" />
                                                                        <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#FF8888"
                                                                            IsVisible="{Binding IsMath}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel IsVisible="{Binding HasMissedCorrectOptions}">
                                        <TextBlock Text="You missed these correct options:" FontSize="14"
                                            Foreground="#FFCC66" />
                                        <ItemsControl ItemsSource="{Binding MissedCorrectOptions}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="sys:String">
                                                    <StackPanel Spacing="6" Margin="0,2,0,0" Orientation="Horizontal">
                                                        <TextBlock Text="•" FontSize="14" Foreground="#FFCC66" VerticalAlignment="Top" />
                                                        <ItemsControl ItemsSource="{Binding ., Converter={StaticResource MixedMathSegmentsConverter}}">
                                                            <ItemsControl.ItemsPanel>
                                                                <ItemsPanelTemplate>
                                                                    <WrapPanel />
                                                                </ItemsPanelTemplate>
                                                            </ItemsControl.ItemsPanel>
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                    <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#FFCC66"
                                                                            IsVisible="{Binding IsText}" />
                                                                        <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                            VerticalAlignment="Center"
                                                                            Foreground="#FFCC66"
                                                                            IsVisible="{Binding IsMath}" />
                                                                    </StackPanel>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Button Content="Next" Click="NextCard_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Match Card -->
                            <StackPanel Spacing="10" IsVisible="{Binding IsMatchCard}">
                                <!-- Input Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding !IsAnswerChecked}">
                                    <TextBlock Text="Match each left item to the correct right item:" FontSize="14"
                                        Foreground="{DynamicResource TextSecondary}" />

                                    <ItemsControl ItemsSource="{Binding MatchRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:ReviewMatchRow">
                                                <Border Background="#18000000" BorderBrush="{DynamicResource CardBorder}"
                                                    BorderThickness="1" CornerRadius="8" Padding="10" Margin="0,2,0,2">
                                                    <Grid ColumnDefinitions="*, Auto, *" VerticalAlignment="Center">
                                                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                            <ItemsControl ItemsSource="{Binding LeftText, Converter={StaticResource MixedMathSegmentsConverter}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                        <StackPanel Margin="0,0,2,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Content}" FontSize="16"
                                                                                VerticalAlignment="Center" TextWrapping="Wrap"
                                                                                Foreground="{DynamicResource TextPrimary}"
                                                                                IsVisible="{Binding IsText}" />
                                                                            <math:FormulaBlock Formula="{Binding Content}" FontSize="16"
                                                                                VerticalAlignment="Center"
                                                                                IsVisible="{Binding IsMath}"
                                                                                Foreground="{DynamicResource TextPrimary}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1" Text="→" Margin="10,0"
                                                            VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}" />
                                                        <ComboBox Grid.Column="2"
                                                            ItemsSource="{Binding RightChoices}"
                                                            SelectedItem="{Binding SelectedRightText, Mode=TwoWay}"
                                                            HorizontalAlignment="Stretch"
                                                            HorizontalContentAlignment="Stretch"
                                                            CornerRadius="8" Padding="8,6">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate x:DataType="sys:String">
                                                                    <ItemsControl ItemsSource="{Binding ., Converter={StaticResource MixedMathSegmentsConverter}}"
                                                                        VerticalAlignment="Center" Margin="2">
                                                                        <ItemsControl.ItemsPanel>
                                                                            <ItemsPanelTemplate>
                                                                                <WrapPanel />
                                                                            </ItemsPanelTemplate>
                                                                        </ItemsControl.ItemsPanel>
                                                                        <ItemsControl.ItemTemplate>
                                                                            <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                                <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                                    <TextBlock Text="{Binding Content}" FontSize="14"
                                                                                        TextWrapping="Wrap"
                                                                                        TextTrimming="None"
                                                                                        VerticalAlignment="Center"
                                                                                        Foreground="{DynamicResource TextPrimary}"
                                                                                        IsVisible="{Binding IsText}" />
                                                                                    <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                                        VerticalAlignment="Center"
                                                                                        IsVisible="{Binding IsMath}"
                                                                                        Foreground="{DynamicResource TextPrimary}" />
                                                                                </StackPanel>
                                                                            </DataTemplate>
                                                                        </ItemsControl.ItemTemplate>
                                                                    </ItemsControl>
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <Button Content="Submit Answer" Click="SubmitAnswer_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                        Background="{DynamicResource GradientStart}" Foreground="{DynamicResource PrimaryButtonForeground}" />
                                </StackPanel>

                                <!-- Result Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsAnswerChecked}">
                                    <TextBlock Text="✓ Correct!" FontSize="24" FontWeight="Bold"
                                        Foreground="#4444FF44" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsAnswerCorrect}" />
                                    <TextBlock Text="✕ Incorrect" FontSize="24" FontWeight="Bold"
                                        Foreground="#FF4444" HorizontalAlignment="Center"
                                        IsVisible="{Binding !IsAnswerCorrect}" />

                                    <StackPanel>
                                        <TextBlock Text="Correct matches:" FontSize="14"
                                            Foreground="{DynamicResource TextSecondary}" />
                                        <ItemsControl ItemsSource="{Binding MatchRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ReviewMatchRow">
                                                    <StackPanel Spacing="0">
                                                        <StackPanel Spacing="4" Orientation="Horizontal" Margin="0,2,0,0">
                                                            <TextBlock Text="•" FontSize="14" Foreground="#44CC88" VerticalAlignment="Top" />
                                                            <ItemsControl ItemsSource="{Binding LeftText, Converter={StaticResource MixedMathSegmentsConverter}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                        <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#44CC88"
                                                                                IsVisible="{Binding IsText}" />
                                                                            <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#44CC88"
                                                                                IsVisible="{Binding IsMath}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                        <StackPanel Spacing="4" Orientation="Horizontal" Margin="0,0,0,2">
                                                            <TextBlock Text="→" FontSize="14" Foreground="#44CC88" Margin="0,0,0,0" VerticalAlignment="Top" />
                                                            <ItemsControl ItemsSource="{Binding CorrectRightText, Converter={StaticResource MixedMathSegmentsConverter}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <WrapPanel />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                        <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                            <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#44CC88"
                                                                                IsVisible="{Binding IsText}" />
                                                                            <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                                VerticalAlignment="Center"
                                                                                Foreground="#44CC88"
                                                                                IsVisible="{Binding IsMath}" />
                                                                        </StackPanel>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </StackPanel>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <StackPanel IsVisible="{Binding HasWrongMatches}">
                                        <TextBlock Text="Incorrect selections:" FontSize="14"
                                            Foreground="#FF8888" />
                                        <ItemsControl ItemsSource="{Binding WrongMatches}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="sys:String">
                                                    <ItemsControl ItemsSource="{Binding ., Converter={StaticResource MixedMathSegmentsConverter}}"
                                                        Margin="0,2,0,0">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <WrapPanel />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate x:DataType="converters:MixedMathSegment">
                                                                <StackPanel Margin="0,0,1,0" Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding Content}" FontSize="14" TextWrapping="Wrap"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#FF8888"
                                                                        IsVisible="{Binding IsText}" />
                                                                    <math:FormulaBlock Formula="{Binding Content}" FontSize="14"
                                                                        VerticalAlignment="Center"
                                                                        Foreground="#FF8888"
                                                                        IsVisible="{Binding IsMath}" />
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>

                                    <Button Content="Next" Click="NextCard_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- True/False Card -->
                            <StackPanel Spacing="10" IsVisible="{Binding IsTrueFalseCard}">
                                <!-- Input Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding !IsAnswerChecked}">
                                    <TextBlock Text="Pick the correct option:" FontSize="14"
                                        Foreground="{DynamicResource TextSecondary}" />

                                    <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
                                        <Button Grid.Column="0" Content="{Binding CurrentTrueFalseTrueOptionText}"
                                            Click="TrueAnswer_Click" FontSize="16"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#2E9E44" Foreground="#FFFFFF" />
                                        <Button Grid.Column="1" Content="{Binding CurrentTrueFalseFalseOptionText}"
                                            Click="FalseAnswer_Click" FontSize="16"
                                            HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                            Background="#CC3D3D" Foreground="#FFFFFF" />
                                    </Grid>
                                </StackPanel>

                                <!-- Result Phase -->
                                <StackPanel Spacing="10" IsVisible="{Binding IsAnswerChecked}">
                                    <TextBlock Text="✓ Correct!" FontSize="24" FontWeight="Bold"
                                        Foreground="#4444FF44" HorizontalAlignment="Center"
                                        IsVisible="{Binding IsAnswerCorrect}" />
                                    <TextBlock Text="✕ Incorrect" FontSize="24" FontWeight="Bold"
                                        Foreground="#FF4444" HorizontalAlignment="Center"
                                        IsVisible="{Binding !IsAnswerCorrect}" />

                                    <StackPanel>
                                        <TextBlock Text="Correct option:" 
                                            Foreground="{DynamicResource TextSecondary}" FontSize="14" />
                                        <TextBlock Text="{Binding CurrentTrueFalseCorrectOptionText}"
                                            Foreground="{DynamicResource TextPrimary}" FontSize="16"
                                            TextWrapping="Wrap" />
                                    </StackPanel>

                                    <Button Content="Next" Click="NextCard_Click"
                                        FontSize="16"
                                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Flip Card: Answer Reveal (Both Flip and Type manual mode) -->
                            <StackPanel Orientation="Horizontal" Spacing="20"
                                HorizontalAlignment="Center" IsVisible="{Binding IsFlipCard}">
                                <Button Content="✕ Incorrect" Click="Incorrect_Click"
                                    FontSize="16"
                                    Background="#60FF4444" Padding="20,10"
                                    MinWidth="170"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding IsAnswerRevealed}" />
                                <Button Content="✓ Correct" Click="Correct_Click"
                                    FontSize="16"
                                    Background="#6044FF44" Padding="20,10"
                                    MinWidth="170"
                                    HorizontalContentAlignment="Center"
                                    IsVisible="{Binding IsAnswerRevealed}" />
                            </StackPanel>
                        </StackPanel>
                        </StackPanel>
                    </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:SummaryViewModel}">
            <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                <Border Width="420" Background="{DynamicResource CardBackground}" CornerRadius="26"
                    Padding="32">
                    <StackPanel Spacing="20" HorizontalAlignment="Center">
                        <StackPanel HorizontalAlignment="Center" Spacing="4">
                            <TextBlock Text="Session Complete!" FontSize="24" FontWeight="Bold" />
                            <TextBlock Text="{Binding SessionMarker}" FontSize="14"
                                Foreground="#FF8D7F" FontStyle="Italic"
                                IsVisible="{Binding IsPartialSession}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Percentage, StringFormat='{}{0}%'}" FontSize="64"
                            FontWeight="Black" Foreground="{DynamicResource GradientStart}" />
                        <TextBlock Text="{Binding Grade, StringFormat='Grade: {0}'}" FontSize="20"
                            Foreground="{DynamicResource TextSecondary}" />
                        <TextBlock Text="{Binding TimeFormatted, StringFormat='Time: {0}'}"
                            FontSize="18" FontWeight="SemiBold"
                            Foreground="{DynamicResource TextSecondary}" />
                        <Button Content="Finish" Click="ReturnToDashboard_Click"
                            HorizontalAlignment="Stretch" Margin="0,20,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </DataTemplate>
    </Window.DataTemplates>

    <Grid>
        <Rectangle Classes="animatedGradient" Width="2800" Height="2800"
            HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="50%,50%">
            <Rectangle.RenderTransform>
                <RotateTransform Angle="0" />
            </Rectangle.RenderTransform>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                    <GradientStop Offset="0.0" Color="{DynamicResource GradientStart}" />
                    <GradientStop Offset="0.5" Color="{DynamicResource GradientMiddle}" />
                    <GradientStop Offset="1.0" Color="{DynamicResource GradientEnd}" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Classes="animatedGradientReverse" Width="2400" Height="2400"
            HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.62" RenderTransformOrigin="50%,50%">
            <Rectangle.RenderTransform>
                <RotateTransform Angle="360" />
            </Rectangle.RenderTransform>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="100%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0.0" Color="{DynamicResource GradientEnd}" />
                    <GradientStop Offset="0.5" Color="{DynamicResource GradientMiddle}" />
                    <GradientStop Offset="1.0" Color="{DynamicResource GradientStart}" />
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <Rectangle Fill="{DynamicResource AppBackground}" Opacity="0.28" IsHitTestVisible="False" />

        <ContentControl Content="{Binding CurrentPage}" />
    </Grid>

</Window>