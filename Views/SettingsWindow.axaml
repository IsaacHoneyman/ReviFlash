<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ReviFlash.ViewModels"
        x:Class="ReviFlash.Views.SettingsWindow"
        x:DataType="vm:SettingsViewModel"
        Title="Settings"
        Width="420" Height="720"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource AppBackground}">

    <ScrollViewer Margin="24"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="16">
            <TextBlock Text="Settings" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
            
            <Border Background="{DynamicResource CardBackground}" 
        BorderBrush="{DynamicResource CardBorder}" 
        BorderThickness="1" 
        CornerRadius="10" 
        Padding="16">
    <StackPanel Spacing="8">
        <TextBlock Text="Application Theme" 
                   FontWeight="SemiBold" 
                   Foreground="{DynamicResource TextPrimary}"/>
        
        <ComboBox ItemsSource="{Binding AvailableThemes}"
                  SelectedItem="{Binding SelectedTheme}"
                  HorizontalAlignment="Stretch"
                  CornerRadius="5"/>
    </StackPanel>
</Border>

            <Border Background="{DynamicResource CardBackground}" 
        BorderBrush="{DynamicResource CardBorder}" 
        BorderThickness="1" 
        CornerRadius="10" 
        Padding="16">
    <StackPanel Spacing="8">
        <TextBlock Text="Review Settings" 
                   FontWeight="SemiBold" 
                   Foreground="{DynamicResource TextPrimary}"/>
        
        <Grid ColumnDefinitions="*, Auto">
            <TextBlock Grid.Column="0" Text="Show Timer During Review" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}"/>
            <CheckBox Grid.Column="1" IsChecked="{Binding ShowTimer}"
                      HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>

        <Grid ColumnDefinitions="*, Auto">
            <TextBlock Grid.Column="0" Text="Show Progress Meter During Review" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextPrimary}"/>
            <CheckBox Grid.Column="1" IsChecked="{Binding ShowProgress}"
                      HorizontalAlignment="Right" VerticalAlignment="Center" />
        </Grid>
    </StackPanel>
</Border>

        <Border Background="{DynamicResource CardBackground}"
            BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="10"
            Padding="16">
        <StackPanel Spacing="10">
            <TextBlock Text="Backup"
                   FontWeight="SemiBold"
                   Foreground="{DynamicResource TextPrimary}"/>

            <TextBlock Text="Create a backup zip or restore the app from an existing backup file."
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondary}"/>

            <Grid ColumnDefinitions="*, *" ColumnSpacing="10">
            <Button Grid.Column="0"
                Content="Create Backup"
                Click="CreateBackup_Click"
                HorizontalAlignment="Stretch"
                CornerRadius="8"
                Padding="12,10"
                FontWeight="Bold"
                Background="{DynamicResource AccentBrush}"
                Foreground="{DynamicResource IconForeground}"
                Cursor="Hand"/>

            <Button Grid.Column="1"
                Content="Restore Backup"
                Click="RestoreBackup_Click"
                HorizontalAlignment="Stretch"
                CornerRadius="8"
                Padding="12,10"
                FontWeight="Bold"
                Background="{DynamicResource CardBorder}"
                Foreground="{DynamicResource TextPrimary}"
                Cursor="Hand"/>
            </Grid>

            <TextBlock x:Name="BackupStatusText"
                   IsVisible="False"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource TextSecondary}"/>
        </StackPanel>
        </Border>

            <Border Background="#33FF4B6E"
                    BorderBrush="#D9FF4B6E"
                    BorderThickness="1.5"
                    CornerRadius="10"
                    Padding="16">
                <StackPanel Spacing="10">
                    <TextBlock Text="Danger Zone"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="#D72649"/>

                    <TextBlock Text="Delete all flashcard stats across every deck. This cannot be undone."
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextPrimary}"/>

                    <Button Content="Delete All Flashcard Stats"
                            Click="DeleteAllStats_Click"
                            HorizontalAlignment="Stretch"
                            CornerRadius="8"
                            Padding="12,10"
                            FontWeight="Bold"
                            Background="#D9D72649"
                            Foreground="{DynamicResource IconForeground}"
                            Cursor="Hand"/>

                    <TextBlock x:Name="DeleteStatsStatusText"
                               IsVisible="False"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <Separator Background="{DynamicResource CardBorder}" Opacity="0.3" Margin="0,8"/>

                    <TextBlock Text="Delete Individual Deck Stats"
                               FontWeight="SemiBold"
                               Foreground="#D72649"/>

                    <TextBlock Text="Delete stats for a specific flashcard set."
                               TextWrapping="Wrap"
                               FontSize="12"
                               Foreground="{DynamicResource TextSecondary}"/>

                    <ComboBox ItemsSource="{Binding AvailableDecks}"
                              SelectedItem="{Binding SelectedDeckForStatDeletion}"
                              HorizontalAlignment="Stretch"
                              CornerRadius="8"
                              Padding="12,8">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Button Content="Delete This Deck's Stats"
                            Click="DeleteDeckStats_Click"
                            HorizontalAlignment="Stretch"
                            CornerRadius="8"
                            Padding="12,10"
                            FontWeight="Bold"
                            IsEnabled="{Binding SelectedDeckForStatDeletion, Converter={x:Static ObjectConverters.IsNotNull}}"
                            Background="#D9D72649"
                            Foreground="{DynamicResource IconForeground}"
                            Cursor="Hand"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>